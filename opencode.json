{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "@upstash/context7-mcp"
      ]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      }
    },
    "docker": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--servers",
        "docker"
      ]
    },
    "postgres": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--servers",
        "database-server"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    }
  }
}
